# Out-Default makes the script wait for programs in the Windows subsystem to exit
# https://stackoverflow.com/a/7272390

# Trace script execution
Set-PSDebug -Trace 2

# curl.exe uses the actual curl shipped in Windows 1804+, not the alias for Invoke-WebRequest

# Pause on cmdlet errors (does not affect external processes)
# <https://learn.microsoft.com/en-us/powershell/module/microsoft.powershell.core/about/about_preference_variables?view=powershell-7.5#erroractionpreference>
$ErrorActionPreference = 'Inquire'

# Stop on external process failures
function Check {
    if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }
}

function Update-SessionEnvironment {
    # This is a bit like what refreshenv / Update-SessionEnvironment used to do in Chocolatey,
    # but in servo/servo#42372 we moved from Chocolatey to WinGet, so we need to roll our own.
    # <https://stackoverflow.com/a/31845512>
    # <https://stackoverflow.com/a/46760714>
    $env:Path = [System.Environment]::GetEnvironmentVariable("Path","Machine") + ";" + [System.Environment]::GetEnvironmentVariable("Path","User")
}

cd C:\ci

if (!(Test-Path .\image-built)) {
    # Install Mozilla’s root certificates, to avoid SSL errors in Python.
    # More details: <https://github.com/python/cpython/issues/80192>
    # Example error: `Error downloading moztools-4.0: [SSL: CERTIFICATE_VERIFY_FAILED] certificate verify failed: unable to get local issuer certificate (_ssl.c:1016). The failing URL was: https://github.com/servo/servo-build-deps/releases/download/msvc-deps/moztools-4.0.zip`
    curl.exe -fsSLO 'http://192.168.100.1:8000/image-deps/windows10/cacert.pfx'; Check
    $pfx_password = ConvertTo-SecureString "servo" -AsPlainText -Force
    Import-PfxCertificate -Password $pfx_password -CertStoreLocation Cert:\LocalMachine\Root -FilePath cacert.pfx

    # In case those are out of date, update certs for servers we know we’ll need.
    Invoke-WebRequest -UseBasicParsing https://github.com | Out-Null
    try {
        # This request is a 404, so we need to try/catch
        Invoke-WebRequest -UseBasicParsing https://release-assets.githubusercontent.com | Out-Null
    } catch {}

    # Install Git
    # Note: installer automatically uninstalls first if needed, so the check is just there to save time
    if (!(Test-Path 'C:\Program Files\Git\cmd\git.exe')) {
        curl.exe -fsSLO 'http://192.168.100.1:8000/image-deps/windows10/Git-2.45.1-64-bit.exe'; Check
        # `CmdTools` is “Use Git and optional Unix tools from the Command Prompt”, and is required
        # by many composite actions expecting to be able to run bash scripts on all platforms.
        # This is what GitHub’s images use, and it does not seem to override stock Windows tools.
        # <https://github.com/git-for-windows/build-extra/pull/653>
        .\Git-2.45.1-64-bit.exe /silent /o:PathOption=CmdTools | Out-Default; Check
    }

    # Install Python, for checkouts without servo#34504
    # Note: installer is idempotent, so the check is just there to save time
    if (!(Test-Path $env:LOCALAPPDATA\Programs\Python\Python310\python.exe)) {
        curl.exe -fsSLO 'http://192.168.100.1:8000/image-deps/windows10/python-3.10.11-amd64.exe'; Check
        .\python-3.10.11-amd64.exe /passive | Out-Default; Check
    }

    # Install uv
    if (!(Test-Path C:\Users\Administrator\.local\bin\uv.exe)) {
        curl.exe -fsSLO 'http://192.168.100.1:8000/image-deps/windows10/uv-installer.ps1'; Check
        .\uv-installer.ps1; Check
    }

    # Install rustup and the latest Rust
    if (!(Test-Path C:\Users\Administrator\.rustup)) {
        curl.exe -fsSLO 'http://192.168.100.1:8000/image-deps/windows10/rustup-init.exe'; Check
        .\rustup-init.exe -y --quiet; Check
    }

    # Install WinGet, which does not ship with Windows 10.
    # Based on: <https://github.com/servo/servo/pull/42372>
    # Based on: <https://learn.microsoft.com/en-us/windows/package-manager/winget/troubleshooting>
    if (!(Test-Path $env:LOCALAPPDATA\Microsoft\WindowsApps\winget.exe)) {
        Install-PackageProvider -Name NuGet -Force
        Install-Module -Name Microsoft.WinGet.Client -Repository PSGallery -Force
        # NOTE: unlike in servo/servo#42372, we do not use `-AllUsers`, to avoid an error:
        # `Deployment failed with HRESULT: 0x80073D06, The package could not be installed because a higher version of this package is already installed.`
        # `Windows cannot install package Microsoft.DesktopAppInstaller_1.0.30251.0_x64__8wekyb3d8bbwe because it has version 1.0.30251.0. A higher version 1.29.280.0 of this package is already installed.`
        Repair-WinGetPackageManager -Latest -Force
    }

    # Install Visual Studio 2022 (17.0), with the components from the Servo book
    # <https://book.servo.org/building/windows.html>
    # See also: <https://github.com/rust-lang/rustup/blob/2a5a69e0914ff419554d684ca71eb1d72c72bcb3/src/cli/self_update/windows.rs#L174>
    # See also: <https://learn.microsoft.com/en-us/visualstudio/install/use-command-line-parameters-to-install-visual-studio?view=vs-2022>
    # See also: the installer’s --help
    if (!(Test-Path .\vswhere.exe)) {
        curl.exe -fsSLO 'http://192.168.100.1:8000/image-deps/windows10/vswhere.exe'; Check
    }
    if ($(.\vswhere.exe -format value -property isComplete) -ne '1') {
        Check
        curl.exe -fsSLO 'http://192.168.100.1:8000/image-deps/windows10/vs_community.exe'; Check
        .\vs_community.exe --wait --focusedUi --addProductLang en-us `
            --add Microsoft.VisualStudio.Component.Windows10SDK.19041 `
            --add Microsoft.VisualStudio.Component.VC.Tools.x86.x64 `
            --add Microsoft.VisualStudio.Component.VC.ATL `
            --passive | Out-Default; Check
    }

    # Update $env:PATH from defaults, to pick up the tools installed above.
    Update-SessionEnvironment

    # Clone and enter the Servo repo
    if (!(Test-Path C:\a\servo\servo)) {
        mkdir -p C:\a\servo
        git clone http://192.168.100.1:8000/cache/servo/.git C:\a\servo\servo; Check
    }
    cd C:\a\servo\servo

    # Fix the remote url, since it’s still set to our cache
    git remote set-url origin https://github.com/servo/servo.git; Check

    .\mach fetch; Check
    .\mach bootstrap-gstreamer; Check

    # Install the Rust toolchain, for checkouts without servo#35795
    rustup show active-toolchain
    if ($LASTEXITCODE -ne 0) {
        rustup toolchain install; Check
    }

    .\mach bootstrap; Check

    # Save a copy of the environment variables that can break incremental builds, for debugging.
    mkdir -p C:\init
    echo "`$env:LIBCLANG_PATH in runner image = $env:LIBCLANG_PATH" > C:\init\incremental_build_debug.txt
    echo "`$env:PATH in runner image = $env:PATH" >> C:\init\incremental_build_debug.txt

    # Work around servo/servo#32302 (see also servo/servo#32300)
    # <https://github.com/servo/servo/issues/32302>
    # <https://github.com/servo/servo/issues/32300>
    $env:RUSTUP_WINDOWS_PATH_ADD_BIN = 1
    # TODO: bake in a build for the libservo/MSRV job
    # Build the same way as a typical Windows libservo job, to allow for incremental builds.
    # cargo build -p libservo --all-targets --profile checked-release --target-dir target\libservo; Check
    # Build the same way as a typical Windows build job, to allow for incremental builds.
    .\mach build --use-crown --locked --profile checked-release; Check

    # Leave the Servo repo
    cd C:\ci

    # Install the GitHub Actions runner
    if (Test-Path .\actions-runner) {
        rm -Recurse -Force actions-runner
    }
    if (!(Test-Path .\actions-runner-win-x64.zip)) {
        curl.exe -fsSLO "http://192.168.100.1:8000/image-deps/windows10/actions-runner-win-x64.zip"; Check
    }
    mkdir -p actions-runner
    cd actions-runner
    Expand-Archive -Path ..\actions-runner-win-x64.zip
    cd ..

    # Check that servoshell was built.
    # This is janky, but we don’t really trust $LASTEXITCODE checks on Windows
    # as much as their counterpart on Unix
    if ((Test-Path C:\a\servo\servo\target\checked-release\servoshell.exe) -or (Test-Path C:\a\servo\servo\target\checked-release\servo.exe)) {
        New-Item C:\ci\image-built
        shutdown /s /t 0
        exit  # `shutdown` does not exit
    }
} else {
    # Use the actual curl shipped in Windows 1804+, not the alias for Invoke-WebRequest
    $jitconfig = curl.exe -fsS --max-time 5 --retry 99 --retry-all-errors http://192.168.100.1:8000/github-jitconfig | ConvertFrom-Json
    if ($jitconfig -ne $null) {
        & C:\ci\actions-runner\actions-runner-win-x64\run.cmd --jitconfig $jitconfig
    }
}
